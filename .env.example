MONGO_USERNAME=data
MONGO_PASSWORD=data

YAGPT_TOKEN=data-data
YAGPT_URL=http://data

# MongoDB Configuration
MONGO_URI=data://data:27017/

MONGO_DATABASE=data
MONGO_COLLECTION=data

# Yandex AI Configuration

YAGPT_MODEL=/data

# Telegram Configuration
TELEGRAM_BOT_TOKEN='data:data'
TELEGRAM_CHANNEL_ID=Id:'-data'

# Optional: Custom LLM Prompt (overrides default fintech trends prompt)
# If not set, the default fintech trends prompt will be used
# LLM_PROMPT=Your custom prompt here...

# Processing Configuration (optional)
BATCH_SIZE=10
DELAY_BETWEEN_REQUESTS=2
MAX_RETRIES=2
LOG_LEVEL=INFO
